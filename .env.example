# --- dash-pay microservice ---
NETWORK=testnet                 # testnet | mainnet
PORT=8090

# backend <-> service auth (matches backend DASH_AUTH_SECRET)
AUTH_SECRET=change-me
# where the service POSTs settlement callbacks (backend public webhook)
CALLBACK_URL=https://your-app.example/webhooks/dash
CALLBACK_SECRET=change-me       # matches backend DASH_CALLBACK_SECRET

# wallet
OWNER_STORAGE_ADDRESS=          # cold/storage Dash address funds are swept to
# Encrypts one-time private keys at rest. Leave EMPTY to auto-generate one on
# first run, persisted next to the DB (data volume) — back it up, never delete
# it (losing it orphans stored keys). For production provide it explicitly, or
# via a mounted secret file: KEYS_ENCRYPTION_SECRET_FILE=/run/secrets/keys_enc
KEYS_ENCRYPTION_SECRET=
# Any of AUTH_SECRET / CALLBACK_SECRET / KEYS_ENCRYPTION_SECRET may instead be
# supplied from a file via the matching <NAME>_FILE env (Docker/K8s secrets).

# oracle (fiat -> DASH)
RATE_CACHE_TTL_SECONDS=60
# Max age of a cached rate served when the upstream is down; beyond this a quote
# fails rather than pricing on a stale rate.
RATE_MAX_STALE_SECONDS=600
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
COINGECKO_DASH_ID=dash

# abuse controls (backend <-> service API)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_OPEN_INTENTS=1000

# payment lifecycle
PAYMENT_WINDOW_SECONDS=900
DEFAULT_INSTANT_SEND=true
DEFAULT_MIN_CONFIRMATIONS=1
# On startup, scan the last N blocks to recover payments missed during downtime.
RECONCILE_LOOKBACK_BLOCKS=30
# Never build a sweep below this (fee + dust would make the tx invalid). Funds
# under this are left on the one-time address for manual handling.
MIN_SWEEP_DUFFS=10000

# storage
DB_PATH=./data/dash-pay.db

# DAPI access: leave EMPTY to auto-discover active evonodes. Override with one or
# more evonode gRPC-web URLs (comma-separated) to pin specific nodes.
# (TLS to evonodes is not verified by cert — payment validity comes from
# ChainLock/InstantLock chain proofs; only the DAPI leg skips verification.)
DAPI_SEEDS=
