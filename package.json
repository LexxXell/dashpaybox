  "private": true,
  "type": "module",
  "description": "Drop-in Dash payments microservice (HTTP API + signed webhook).",
  "license": "MIT",
  "author": "LexxXell",
  "homepage": "https://github.com/lexxxell/dashpaybox#readme",
  "repository": {
